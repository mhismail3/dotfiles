#!/usr/bin/env bash

# .macos — System preferences for server-laptop (M5 Max MacBook Pro)
# Run: source ~/.dotfiles/macos/.macos

osascript -e 'tell application "System Settings" to quit' 2>/dev/null || true

sudo -v < /dev/tty
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

MACOS_USER="${MACOS_USER:-$(whoami)}"

###############################################################################
# Computer Name
###############################################################################

echo -n "Enter device name [server-laptop]: "
read DEVICE_NAME </dev/tty 2>/dev/null || DEVICE_NAME=""
DEVICE_NAME="${DEVICE_NAME:-server-laptop}"

echo "Setting computer name to $DEVICE_NAME..."
sudo scutil --set ComputerName "$DEVICE_NAME"
sudo scutil --set HostName "$DEVICE_NAME"
sudo scutil --set LocalHostName "$DEVICE_NAME"
sudo defaults write /Library/Preferences/SystemConfiguration/com.apple.smbd.plist NetBIOSName -string "$DEVICE_NAME"

###############################################################################
# Remote Access (SSH + Screen Sharing + Remote Management)
###############################################################################

echo "Enabling remote access..."

sudo systemsetup -setremotelogin on 2>/dev/null || \
    sudo launchctl load -w /System/Library/LaunchDaemons/ssh.plist 2>/dev/null || \
    echo "  Enable manually: System Settings > General > Sharing > Remote Login"

sudo dseditgroup -o create -q com.apple.access_ssh 2>/dev/null || true
sudo dseditgroup -o edit -a "$MACOS_USER" -t user com.apple.access_ssh 2>/dev/null || true


if [[ -f "/System/Library/CoreServices/RemoteManagement/ARDAgent.app/Contents/Resources/kickstart" ]]; then
    sudo /System/Library/CoreServices/RemoteManagement/ARDAgent.app/Contents/Resources/kickstart \
        -activate -configure -access -on \
        -allowAccessFor -allUsers \
        -restart -agent -privs -all 2>/dev/null || \
        echo "  Enable manually: System Settings > General > Sharing > Remote Management"

    # Allow anyone to request permission to control screen
    sudo defaults write /Library/Preferences/com.apple.RemoteManagement VNCAlwaysStartOnConsole -bool true

    # Enable VNC with password
    echo -n "Set VNC password (leave blank to skip): "
    read -s VNC_PASSWORD </dev/tty 2>/dev/null || VNC_PASSWORD=""
    echo ""
    if [[ -n "$VNC_PASSWORD" ]]; then
        sudo /System/Library/CoreServices/RemoteManagement/ARDAgent.app/Contents/Resources/kickstart \
            -configure -clientopts -setvnclegacy -vnclegacy yes \
            -setvncpw -vncpw "$VNC_PASSWORD" 2>/dev/null || \
            echo "  Set VNC password manually: System Settings > General > Sharing > Remote Management"
    fi
fi

###############################################################################
# Power Management — AC (plugged in: always-on server)
###############################################################################

echo "Configuring power management (AC/charger)..."

sudo pmset -c sleep 0              # Never sleep
sudo pmset -c displaysleep 10      # Display off after 10 min
sudo pmset -c disksleep 0          # Never spin down disks
sudo pmset -c hibernatemode 0      # No hibernation (fast wake, no disk image)
sudo pmset -c standby 0            # No deep sleep after idle
sudo pmset -c womp 1               # Wake on LAN (requires Ethernet adapter)
sudo pmset -c acwake 1             # Wake when power source changes
sudo pmset -c lidwake 1            # Wake when lid opens
sudo pmset -c tcpkeepalive 1       # Keep TCP connections alive
sudo pmset -c ttyskeepawake 1      # SSH sessions prevent sleep
sudo pmset -c powernap 1           # Background tasks during sleep (safety net)
sudo pmset -c proximitywake 0      # No random wakes from iPhone nearby
sudo pmset -c autorestart 1        # Restart after power failure (best-effort on laptops)

###############################################################################
# Power Management — Battery (unplugged: laptop mode)
###############################################################################

echo "Configuring power management (battery)..."

sudo pmset -b sleep 30             # Sleep after 30 min idle
sudo pmset -b displaysleep 10      # Display off after 10 min
sudo pmset -b disksleep 10          # Spin down before sleep (SSD, minimal impact)
sudo pmset -b hibernatemode 3      # RAM + disk image (safe if battery dies)
sudo pmset -b standby 1            # Enter deep sleep eventually
sudo pmset -b standbydelayhigh 900 # 15 min before deep sleep (battery > 50%)
sudo pmset -b standbydelaylow 300  # 5 min before deep sleep (battery < 50%)
sudo pmset -b womp 0               # No WoL on battery (WiFi can't do it anyway)
sudo pmset -b acwake 1             # Wake when plugged back in
sudo pmset -b lidwake 1            # Wake when lid opens
sudo pmset -b tcpkeepalive 1       # Keep connections alive
sudo pmset -b ttyskeepawake 1      # SSH sessions prevent sleep
sudo pmset -b powernap 1           # Background tasks during sleep
sudo pmset -b proximitywake 0      # No random wakes from iPhone
sudo pmset -b autorestart 1        # Restart after power failure (best-effort)

###############################################################################
# Lid-Closed Operation (disablesleep)
###############################################################################

echo "Configuring lid-closed operation..."

sudo pmset -c disablesleep 1

DISABLESLEEP_PLIST="/Library/LaunchDaemons/com.local.disablesleep.plist"
sudo tee "$DISABLESLEEP_PLIST" > /dev/null << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.disablesleep</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/pmset</string>
        <string>-c</string>
        <string>disablesleep</string>
        <string>1</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
EOF
sudo chown root:wheel "$DISABLESLEEP_PLIST"
sudo chmod 644 "$DISABLESLEEP_PLIST"
sudo launchctl bootstrap system "$DISABLESLEEP_PLIST" 2>/dev/null || true

###############################################################################
# Auto-Restart on Freeze
###############################################################################

echo "Enabling auto-restart on freeze..."
sudo systemsetup -setrestartfreeze on 2>/dev/null || true

###############################################################################
# Auto-Login
###############################################################################

echo "Configuring auto-login for $MACOS_USER..."
sudo defaults write /Library/Preferences/com.apple.loginwindow autoLoginUser -string "$MACOS_USER"

###############################################################################
# UI/UX
###############################################################################

echo "Configuring UI..."

defaults write NSGlobalDomain AppleInterfaceStyle -string "Dark"
defaults write NSGlobalDomain NSDocumentSaveNewDocumentsToCloud -bool false
defaults write com.apple.LaunchServices LSQuarantine -bool false

# Default browser to Chrome
open -a "Google Chrome" --args --make-default-browser 2>/dev/null || true

# Disable autocorrect/smart text
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false

###############################################################################
# Dock
###############################################################################

echo "Configuring Dock..."

defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock autohide-delay -float 0
defaults write com.apple.dock autohide-time-modifier -float 0.3
defaults write com.apple.dock tilesize -int 80
defaults write com.apple.dock magnification -bool true
defaults write com.apple.dock largesize -int 100
defaults write com.apple.dock show-recents -bool false
defaults write com.apple.dock show-recent-count -int 0
defaults write com.apple.dock orientation -string "bottom"

# Dock app layout
if command -v dockutil &>/dev/null; then
    echo "Setting Dock layout..."
    dockutil --remove all --no-restart
    dockutil --add "/Applications/Google Chrome.app" --no-restart
    dockutil --add /Applications/Cursor.app --no-restart
    dockutil --add /Applications/Claude.app --no-restart
    dockutil --add /Applications/Codex.app --no-restart
    dockutil --add /Applications/Ghostty.app --no-restart
    dockutil --add /Applications/Xcode.app --no-restart
    dockutil --add /Applications/Tailscale.app --no-restart
    dockutil --add "/Applications/1Password.app" --no-restart
    dockutil --add "/System/Applications/System Settings.app" --no-restart
fi

###############################################################################
# Desktop & Window Manager
###############################################################################

echo "Configuring desktop..."

defaults write com.apple.WindowManager GloballyEnabled -bool false
defaults write com.apple.WindowManager EnableStandardClickToShowDesktop -bool true
defaults write com.apple.WindowManager StandardHideWidgets -int 1
defaults write com.apple.WindowManager StageManagerHideWidgets -int 1

###############################################################################
# Siri
###############################################################################

echo "Disabling Siri..."

defaults write com.apple.assistant.support "Assistant Enabled" -bool false
defaults write com.apple.Siri StatusMenuVisible -bool false
defaults write com.apple.Siri UserHasDeclinedEnable -bool true
launchctl disable "user/$UID/com.apple.assistantd" 2>/dev/null || true
launchctl disable "user/$UID/com.apple.Siri.agent" 2>/dev/null || true

###############################################################################
# Menu Bar
###############################################################################

echo "Configuring menu bar..."

# Hide Spotlight icon from menu bar
defaults -currentHost write com.apple.Spotlight MenuItemHidden -int 1

# Clock: 24-hour, show date, show seconds
defaults write com.apple.menuextra.clock DateFormat -string "EEE d MMM HH:mm:ss"
defaults write com.apple.menuextra.clock Show24Hour -bool true
defaults write com.apple.menuextra.clock ShowDate -int 1
defaults write com.apple.menuextra.clock ShowSeconds -bool true

# Show battery percentage
defaults write com.apple.controlcenter "NSStatusItem Visible Battery" -bool true
defaults -currentHost write com.apple.controlcenter BatteryShowPercentage -bool true

# Hide WiFi from menu bar (still accessible in Control Center)
defaults write com.apple.controlcenter "NSStatusItem Visible WiFi" -bool false

# Hide Focus from menu bar
defaults write com.apple.controlcenter "NSStatusItem Visible FocusModes" -bool false

###############################################################################
# Display
###############################################################################

echo "Configuring display..."

# Disable Night Shift
defaults write com.apple.CoreBrightness CBBlueReductionStatus -dict AutoBlueReductionEnabled -bool false
# Disable True Tone (may not persist via defaults on all machines)
defaults write com.apple.CoreBrightness AutoBrightnessEnable -bool false 2>/dev/null || true

###############################################################################
# Finder
###############################################################################

echo "Configuring Finder..."

defaults write NSGlobalDomain AppleShowAllExtensions -bool true
defaults write com.apple.finder AppleShowAllFiles -bool true
defaults write com.apple.finder ShowPathbar -bool true
defaults write com.apple.finder ShowStatusBar -bool true
defaults write com.apple.finder FXPreferredViewStyle -string "clmv"
defaults write com.apple.finder NewWindowTarget -string "PfLo"
defaults write com.apple.finder NewWindowTargetPath -string "file://${HOME}/Downloads/"
defaults write com.apple.finder FXDefaultSearchScope -string "SCev"
defaults write com.apple.finder _FXSortFoldersFirst -bool true
defaults write com.apple.finder FXEnableExtensionChangeWarning -bool true
defaults write com.apple.finder FinderSpawnTab -bool true
defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool false
defaults write com.apple.finder ShowHardDrivesOnDesktop -bool false
defaults write com.apple.finder ShowMountedServersOnDesktop -bool false
defaults write com.apple.finder ShowRemovableMediaOnDesktop -bool false
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true
chflags nohidden ~/Library 2>/dev/null

###############################################################################
# Keyboard
###############################################################################

echo "Configuring keyboard..."

defaults write NSGlobalDomain KeyRepeat -int 2
defaults write NSGlobalDomain InitialKeyRepeat -int 15
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false
defaults write NSGlobalDomain AppleKeyboardUIMode -int 3

###############################################################################
# Spotlight (only index useful categories)
###############################################################################

echo "Configuring Spotlight..."

defaults write com.apple.spotlight orderedItems -array \
    '{"enabled" = 1;"name" = "APPLICATIONS";}' \
    '{"enabled" = 1;"name" = "SYSTEM_PREFS";}' \
    '{"enabled" = 1;"name" = "DIRECTORIES";}' \
    '{"enabled" = 1;"name" = "DOCUMENTS";}' \
    '{"enabled" = 0;"name" = "FONTS";}' \
    '{"enabled" = 0;"name" = "MESSAGES";}' \
    '{"enabled" = 0;"name" = "CONTACT";}' \
    '{"enabled" = 0;"name" = "EVENT_TODO";}' \
    '{"enabled" = 0;"name" = "IMAGES";}' \
    '{"enabled" = 0;"name" = "BOOKMARKS";}' \
    '{"enabled" = 0;"name" = "MUSIC";}' \
    '{"enabled" = 0;"name" = "MOVIES";}' \
    '{"enabled" = 0;"name" = "PRESENTATIONS";}' \
    '{"enabled" = 0;"name" = "SPREADSHEETS";}' \
    '{"enabled" = 0;"name" = "SOURCE";}' \
    '{"enabled" = 0;"name" = "MENU_DEFINITION";}' \
    '{"enabled" = 0;"name" = "MENU_OTHER";}' \
    '{"enabled" = 0;"name" = "MENU_CONVERSION";}' \
    '{"enabled" = 0;"name" = "MENU_EXPRESSION";}' \
    '{"enabled" = 0;"name" = "PDF";}' \
    '{"enabled" = 0;"name" = "MENU_WEBSEARCH";}' \
    '{"enabled" = 0;"name" = "MENU_SPOTLIGHT_SUGGESTIONS";}'

###############################################################################
# Screen Time
###############################################################################

echo "Disabling Screen Time..."

defaults write com.apple.ScreenTime Enabled -bool false 2>/dev/null || true

###############################################################################
# Privacy — Minimize data sharing
###############################################################################

echo "Minimizing analytics and tracking..."

# Disable analytics
defaults write com.apple.CrashReporter DialogType -string "none"
defaults write com.apple.appleseed.FeedbackAssistant Autogather -bool false
sudo defaults write /Library/Application\ Support/CrashReporter/DiagnosticMessagesHistory.plist AutoSubmit -bool false 2>/dev/null || true

# Disable personalized ads
defaults write com.apple.AdLib allowApplePersonalizedAdvertising -bool false
defaults write com.apple.AdLib allowIdentifierForAdvertising -bool false

###############################################################################
# Security
###############################################################################

echo "Configuring security..."

defaults write com.apple.screensaver askForPassword -int 1
defaults write com.apple.screensaver askForPasswordDelay -int 0

###############################################################################
# Software Updates
###############################################################################

echo "Configuring software updates (download only, no auto-install)..."

defaults write com.apple.SoftwareUpdate AutomaticCheckEnabled -bool true
defaults write com.apple.SoftwareUpdate AutomaticDownload -bool true
defaults write com.apple.SoftwareUpdate CriticalUpdateInstall -bool false
defaults write com.apple.SoftwareUpdate AutomaticallyInstallMacOSUpdates -bool false
defaults write com.apple.commerce AutoUpdate -bool true

###############################################################################
# Caps Lock -> Command
###############################################################################

echo "Remapping Caps Lock to Command..."

KEYREMAP_PLIST="/Library/LaunchDaemons/com.local.KeyRemapping.plist"

sudo tee "$KEYREMAP_PLIST" > /dev/null << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.KeyRemapping</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/hidutil</string>
        <string>property</string>
        <string>--set</string>
        <string>{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000039,"HIDKeyboardModifierMappingDst":0x7000000E3}]}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
EOF

sudo chown root:wheel "$KEYREMAP_PLIST"
sudo chmod 644 "$KEYREMAP_PLIST"
sudo launchctl bootstrap system "$KEYREMAP_PLIST" 2>/dev/null || true
sudo hidutil property --set '{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000039,"HIDKeyboardModifierMappingDst":0x7000000E3}]}'

###############################################################################
# Restart affected apps
###############################################################################

echo "Restarting affected apps..."

for app in "Finder" "Dock" "SystemUIServer" "ControlCenter" "WindowManager"; do
    killall "${app}" &>/dev/null || true
done

###############################################################################
# MANUAL STEPS — DO THESE NOW
###############################################################################

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  MANUAL STEPS — DO THESE NOW"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "  1. INSTALL XCODE"
echo "     Open the App Store and install Xcode, then run:"
echo "     sudo xcodebuild -license accept"
echo ""
echo "  2. DISABLE FILEVAULT (required for auto-login)"
echo "     System Settings > Privacy & Security > FileVault > Turn Off"
echo "     This may take a while to decrypt. Wait for it to complete."
echo ""
echo "  3. ENABLE AUTO-LOGIN"
echo "     System Settings > Users & Groups > Login Options"
echo "     Set 'Automatic Login' to your user."
echo "     (Only appears after FileVault is off.)"
echo ""
echo "  4. ICLOUD DESKTOP & DOCUMENTS"
echo "     System Settings > Apple Account > iCloud > iCloud Drive"
echo "     Turn on 'Desktop & Documents Folders'"
echo ""
echo "  5. BATTERY CHARGE LIMIT"
echo "     System Settings > Battery > Charging > Charge Limit"
echo "     Set to 80%."
echo ""
echo "  6. VERIFY REMOTE LOGIN (SSH)"
echo "     System Settings > General > Sharing > Remote Login"
echo "     Ensure ON and your user is allowed."
echo ""
echo "  7. VERIFY SCREEN SHARING"
echo "     System Settings > General > Sharing > Screen Sharing"
echo "     Ensure ON."
echo ""
echo "  8. ENERGY SETTINGS"
echo "     System Settings > Battery > Options (when plugged in)"
echo "     Turn ON 'Prevent automatic sleeping when the display is off'"
echo ""
echo "  9. LOCK SCREEN"
echo "     System Settings > Lock Screen"
echo "     'Turn display off on battery when inactive': 10 min"
echo "     'Turn display off on power adapter when inactive': 10 min"
echo ""
echo "  10. FIREWALL"
echo "     System Settings > Network > Firewall"
echo "     Enable and allow connections for:"
echo "       - SSH (Remote Login)"
echo "       - Screen Sharing"
echo "       - RustDesk"
echo "       - Tailscale"
echo "       - Ollama (port 11434)"
echo "       - Docker services"
echo ""
echo "  11. WI-FI"
echo "     System Settings > Wi-Fi"
echo "     Join your home network and enable auto-join."
echo ""
echo "  12. FOCUS MODE (optional)"
echo "      System Settings > Focus"
echo "      Create a 'Server' focus mode that suppresses non-critical"
echo "      notifications. Set it to activate automatically."
echo ""
echo "  13. LOCATION SERVICES"
echo "      System Settings > Privacy & Security > Location Services"
echo "      Disable or limit to only system services (Find My Mac)."
echo ""
echo "  14. FULL DISK ACCESS FOR AUTOMATION"
echo "      System Settings > Privacy & Security > Full Disk Access"
echo "      Add Terminal.app and/or Ghostty."
echo ""
echo "  15. STATIC IP / DHCP RESERVATION"
echo "      On your router, assign a fixed IP to $DEVICE_NAME's MAC address."
echo ""
echo "  16. DISABLE TRUE TONE (verify)"
echo "      System Settings > Displays > True Tone"
echo "      Turn OFF (the defaults write may not stick on all machines)."
echo ""
echo "  17. TEST LID-CLOSED OPERATION"
echo "      After completing all steps and restarting:"
echo "      a. Close the MacBook lid"
echo "      b. From another device: ssh $MACOS_USER@$DEVICE_NAME.local"
echo "      c. Or: connect via RustDesk over Tailscale"
echo "      d. If not responding, open lid and check: pmset -g (verify disablesleep = 1)"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  FUTURE ENHANCEMENTS — DO LATER"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "  MONITORING & NOTIFICATIONS"
echo "    Set up health monitoring with ntfy.sh + healthchecks.io:"
echo "    - Shell script checks disk/CPU/RAM every 5 min (LaunchAgent)"
echo "    - Alerts via ntfy.sh push notifications to your phone"
echo "    - Heartbeat to healthchecks.io (alerts if server goes fully down)"
echo "    - Install ntfy app on phone, create free healthchecks.io account"
echo ""
echo "  BACKUPS"
echo "    Time Machine to Synology NAS:"
echo "    - Enable Time Machine service on Synology (DSM > Control Panel)"
echo "    - On Mac: System Settings > General > Time Machine > Add Backup Disk"
echo "    - Or: sudo tmutil setdestination /Volumes/YourTimeMachineShare"
echo "    Consider also: restic to Backblaze B2 for offsite backup"
echo ""
echo "  SSH HARDENING (if exposing SSH outside Tailscale)"
echo "    - Disable password auth: PasswordAuthentication no"
echo "    - Disable root login: PermitRootLogin no"
echo "    - Limit attempts: MaxAuthTries 3"
echo "    - Edit /etc/ssh/sshd_config and restart sshd"
echo ""
echo "  SCHEDULED MAINTENANCE"
echo "    Weekly LaunchAgent to run:"
echo "    - brew update && brew upgrade && brew cleanup"
echo "    - docker system prune -f"
echo "    - Report results via ntfy"
echo ""
echo "  SYSTEM AUDIT / CHANGE TRACKING"
echo "    Periodic snapshot script that diffs machine state:"
echo "    - Brew packages & casks installed/removed"
echo "    - Global npm/pip/cargo packages"
echo "    - Login Items & Extensions"
echo "    - LaunchAgents and LaunchDaemons"
echo "    - /Applications contents"
echo "    - TCC/Privacy permissions (Full Disk Access, Accessibility)"
echo "    - Firewall rules and open ports"
echo "    - Run via LaunchAgent, store diffs in ~/.local/audit/"
echo ""
echo "  THERMAL NOTE"
echo "    Running with lid closed reduces airflow. Monitor temps under load:"
echo "      sudo powermetrics --samplers smc -i 5000 -n 1 | grep -i temp"
echo "    Consider propping the lid slightly open if thermals are an issue."
echo ""
echo "  After completing the manual steps above, RESTART to apply everything."
echo ""

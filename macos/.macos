#!/usr/bin/env bash

# ~/.macos — macOS preferences for agent-focused Mac Mini
# Run by start.sh or standalone: source ~/.dotfiles/macos/.macos

###############################################################################
# Preamble
###############################################################################

osascript -e 'tell application "System Preferences" to quit' 2>/dev/null || true
osascript -e 'tell application "System Settings" to quit' 2>/dev/null || true

sudo -v < /dev/tty

while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

###############################################################################
# Remote Access (SSH + Screen Sharing)
###############################################################################

MACOS_USER="${MACOS_USER:-$(whoami)}"

echo "Enabling Remote Access..."

# Enable Remote Login (SSH)
sudo systemsetup -setremotelogin on 2>/dev/null || {
    echo "⚠️  Could not enable SSH via systemsetup."
    echo "   Please enable manually: System Settings → General → Sharing → Remote Login"
}

# Restrict SSH to specific user
sudo dseditgroup -o create -q com.apple.access_ssh 2>/dev/null || true
sudo dseditgroup -o edit -a "$MACOS_USER" -t user com.apple.access_ssh 2>/dev/null || true

# Enable Screen Sharing
sudo launchctl load -w /System/Library/LaunchDaemons/com.apple.screensharing.plist 2>/dev/null || {
    echo "⚠️  Could not enable Screen Sharing via launchctl."
    echo "   Please enable manually: System Settings → General → Sharing → Screen Sharing"
}

# Enable Remote Management (ARD)
if [[ -f "/System/Library/CoreServices/RemoteManagement/ARDAgent.app/Contents/Resources/kickstart" ]]; then
    sudo /System/Library/CoreServices/RemoteManagement/ARDAgent.app/Contents/Resources/kickstart \
        -activate -configure -access -on \
        -restart -agent -privs -all 2>/dev/null || {
        echo "⚠️  Could not configure Remote Management."
        echo "   Please enable manually: System Settings → General → Sharing → Remote Management"
    }
fi

###############################################################################
# Power Management (always-on server)
###############################################################################

echo "Configuring Power Management..."

sudo pmset -a sleep 0
sudo pmset -a displaysleep 10
sudo pmset -a disksleep 0
sudo pmset -a womp 1
sudo pmset -a autorestart 1
sudo pmset -a hibernatemode 0
sudo systemsetup -setrestartfreeze on 2>/dev/null || true

###############################################################################
# General UI/UX (simplified)
###############################################################################

echo "Configuring UI preferences..."

# Dark mode
defaults write NSGlobalDomain AppleInterfaceStyle -string "Dark"

# Save to disk (not iCloud) by default
defaults write NSGlobalDomain NSDocumentSaveNewDocumentsToCloud -bool false

# Disable auto-correct, smart quotes/dashes (for coding)
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false

# Disable "Are you sure you want to open?" dialog
defaults write com.apple.LaunchServices LSQuarantine -bool false

###############################################################################
# Desktop & Stage Manager
###############################################################################

echo "Configuring Desktop..."

# Stage Manager: off
defaults write com.apple.WindowManager GloballyEnabled -bool false

# Click wallpaper to show desktop: always
defaults write com.apple.WindowManager EnableStandardClickToShowDesktop -bool true

# Hide widgets on desktop
defaults write com.apple.WindowManager StandardHideWidgets -int 1
defaults write com.apple.WindowManager StageManagerHideWidgets -int 1

killall WindowManager 2>/dev/null || true

###############################################################################
# Finder
###############################################################################

echo "Configuring Finder..."

defaults write NSGlobalDomain AppleShowAllExtensions -bool true
defaults write com.apple.finder AppleShowAllFiles -bool true
defaults write com.apple.finder ShowPathbar -bool true
defaults write com.apple.finder ShowStatusBar -bool true
defaults write com.apple.finder FXPreferredViewStyle -string "clmv"
defaults write com.apple.finder NewWindowTarget -string "PfLo"
defaults write com.apple.finder NewWindowTargetPath -string "file://${HOME}/Downloads/"
defaults write com.apple.finder FXDefaultSearchScope -string "SCev"
defaults write com.apple.finder _FXSortFoldersFirst -bool true
defaults write com.apple.finder _FXSortFoldersFirstOnDesktop -bool false
defaults write com.apple.finder FXEnableExtensionChangeWarning -bool true
defaults write com.apple.finder WarnOnEmptyTrash -bool true
defaults write com.apple.finder FXRemoveOldTrashItems -bool false
defaults write com.apple.finder FinderSpawnTab -bool true
defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool false
defaults write com.apple.finder ShowHardDrivesOnDesktop -bool false
defaults write com.apple.finder ShowMountedServersOnDesktop -bool false
defaults write com.apple.finder ShowRemovableMediaOnDesktop -bool false
defaults write com.apple.finder FavoriteTagNames -array
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true
chflags nohidden ~/Library 2>/dev/null

###############################################################################
# Keyboard & Input
###############################################################################

echo "Configuring Keyboard..."

defaults write NSGlobalDomain KeyRepeat -int 2
defaults write NSGlobalDomain InitialKeyRepeat -int 15
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false
defaults write NSGlobalDomain AppleKeyboardUIMode -int 3

###############################################################################
# Lock Screen & Security
###############################################################################

echo "Configuring Security..."

defaults write com.apple.screensaver askForPassword -int 1
defaults write com.apple.screensaver askForPasswordDelay -int 0
sudo defaults write /Library/Preferences/com.apple.loginwindow SHOWFULLNAME -bool true
sudo defaults write /Library/Preferences/com.apple.loginwindow PowerOffDisabled -bool false
sudo defaults write /Library/Preferences/com.apple.loginwindow AdminHostInfo HostName

###############################################################################
# Software Updates
###############################################################################

echo "Configuring Software Updates..."

defaults write com.apple.SoftwareUpdate AutomaticCheckEnabled -bool true
defaults write com.apple.SoftwareUpdate AutomaticDownload -bool true
defaults write com.apple.SoftwareUpdate CriticalUpdateInstall -bool true
defaults write com.apple.commerce AutoUpdate -bool true

###############################################################################
# Disable Spotlight Shortcuts (free Cmd+Space for Raycast)
###############################################################################

echo "Disabling Spotlight shortcuts..."

SPOTLIGHT_PLIST="$HOME/Library/Preferences/com.apple.symbolichotkeys.plist"

disable_spotlight_shortcuts() {
    /usr/libexec/PlistBuddy "$SPOTLIGHT_PLIST" \
        -c "Delete :AppleSymbolicHotKeys:64" \
        -c "Add :AppleSymbolicHotKeys:64:enabled bool false" \
        -c "Add :AppleSymbolicHotKeys:64:value:parameters array" \
        -c "Add :AppleSymbolicHotKeys:64:value:parameters: integer 65535" \
        -c "Add :AppleSymbolicHotKeys:64:value:parameters: integer 49" \
        -c "Add :AppleSymbolicHotKeys:64:value:parameters: integer 1048576" \
        -c "Add :AppleSymbolicHotKeys:64:value:type string standard" 2>/dev/null || {
        /usr/libexec/PlistBuddy "$SPOTLIGHT_PLIST" \
            -c "Add :AppleSymbolicHotKeys:64:enabled bool false" \
            -c "Add :AppleSymbolicHotKeys:64:value:parameters array" \
            -c "Add :AppleSymbolicHotKeys:64:value:parameters: integer 65535" \
            -c "Add :AppleSymbolicHotKeys:64:value:parameters: integer 49" \
            -c "Add :AppleSymbolicHotKeys:64:value:parameters: integer 1048576" \
            -c "Add :AppleSymbolicHotKeys:64:value:type string standard" 2>/dev/null || true
    }

    /usr/libexec/PlistBuddy "$SPOTLIGHT_PLIST" \
        -c "Delete :AppleSymbolicHotKeys:65" \
        -c "Add :AppleSymbolicHotKeys:65:enabled bool false" \
        -c "Add :AppleSymbolicHotKeys:65:value:parameters array" \
        -c "Add :AppleSymbolicHotKeys:65:value:parameters: integer 65535" \
        -c "Add :AppleSymbolicHotKeys:65:value:parameters: integer 49" \
        -c "Add :AppleSymbolicHotKeys:65:value:parameters: integer 1572864" \
        -c "Add :AppleSymbolicHotKeys:65:value:type string standard" 2>/dev/null || {
        /usr/libexec/PlistBuddy "$SPOTLIGHT_PLIST" \
            -c "Add :AppleSymbolicHotKeys:65:enabled bool false" \
            -c "Add :AppleSymbolicHotKeys:65:value:parameters array" \
            -c "Add :AppleSymbolicHotKeys:65:value:parameters: integer 65535" \
            -c "Add :AppleSymbolicHotKeys:65:value:parameters: integer 49" \
            -c "Add :AppleSymbolicHotKeys:65:value:parameters: integer 1572864" \
            -c "Add :AppleSymbolicHotKeys:65:value:type string standard" 2>/dev/null || true
    }
}

if disable_spotlight_shortcuts; then
    echo "✓ Spotlight shortcuts disabled (Cmd+Space freed for Raycast)"
    /System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u 2>/dev/null && \
        echo "✓ Keyboard shortcut changes applied immediately" || \
        echo "⚠️  Could not apply immediately. Changes will take effect after logout."
else
    echo "⚠️  Could not disable Spotlight shortcuts."
fi

###############################################################################
# Caps Lock → Command
###############################################################################

echo "Configuring Caps Lock → Command remap..."

PLIST_PATH="/Library/LaunchDaemons/com.local.KeyRemapping.plist"

sudo tee "$PLIST_PATH" > /dev/null << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.KeyRemapping</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/hidutil</string>
        <string>property</string>
        <string>--set</string>
        <string>{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000039,"HIDKeyboardModifierMappingDst":0x7000000E3}]}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
EOF

sudo chown root:wheel "$PLIST_PATH"
sudo chmod 644 "$PLIST_PATH"
sudo launchctl bootstrap system "$PLIST_PATH" 2>/dev/null || true
sudo hidutil property --set '{"UserKeyMapping":[{"HIDKeyboardModifierMappingSrc":0x700000039,"HIDKeyboardModifierMappingDst":0x7000000E3}]}'

###############################################################################
# Synology Drive Client
###############################################################################

SYNOLOGY_DB="$HOME/Library/Application Support/SynologyDrive/data/db/sys.sqlite"

if [[ -f "$SYNOLOGY_DB" ]]; then
    echo "Configuring Synology Drive Client..."

    TABLES=$(sqlite3 "$SYNOLOGY_DB" ".tables" 2>/dev/null)
    if [[ "$TABLES" != *"system_table"* ]]; then
        echo "⚠️  Synology Drive database structure unexpected. Skipping."
    else
        NOTIF_EXISTS=$(sqlite3 "$SYNOLOGY_DB" "SELECT COUNT(*) FROM system_table WHERE key = 'enable_desktop_notification';" 2>/dev/null)
        ICON_EXISTS=$(sqlite3 "$SYNOLOGY_DB" "SELECT COUNT(*) FROM system_table WHERE key = 'use_black_white_icon';" 2>/dev/null)

        if [[ "$NOTIF_EXISTS" == "1" ]] && [[ "$ICON_EXISTS" == "1" ]]; then
            sqlite3 "$SYNOLOGY_DB" "UPDATE system_table SET value = '0' WHERE key = 'enable_desktop_notification';"
            sqlite3 "$SYNOLOGY_DB" "UPDATE system_table SET value = '1' WHERE key = 'use_black_white_icon';"
            echo "✓ Synology Drive Client configured"
        fi
    fi
else
    echo "⚠️  Synology Drive Client not installed yet. Skipping."
fi

###############################################################################
# Restart affected apps
###############################################################################

echo "Restarting affected apps..."

for app in "Finder" "SystemUIServer" "ControlCenter" "WindowManager"; do
    killall "${app}" &> /dev/null || true
done

echo ""
echo "✅ .macos complete!"
echo ""
echo "Note: Some settings may require logout/restart to take effect."
